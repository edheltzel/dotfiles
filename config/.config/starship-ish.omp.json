    "template": "vesper"
  },
  "transient_prompt": {
    "template": "❯ ",
    "foreground": "p:success",
    "background": "transparent"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "options": {
            "folder_icon": "…",
            "hide_root_location": true,
            "style": "agnoster_short"
          },
          "cache": {
            "duration": "none",
            "strategy": "folder"
          },
          "template": "<p:blue>{{ .Var.lightning }}</><b>{{ .Path }} </b>",
          "foreground": "p:purple",
          "type": "path",
          "style": "plain"
        },
        {
          "options": {
            "branch_icon": " ",
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "disable_with_jj": true
          },
          "cache": {
            "duration": "none",
            "strategy": "folder"
          },
          "template": "<p:muted>on</> {{ .HEAD }}{{ if .LatestTag }} <p:blue>󰓹 {{ .LatestTag }}</>{{ end }}{{if .BranchStatus }} <p:git_ahead>{{ .BranchStatus }}</>{{ end }}{{ if .Working.Changed }} <p:git_modified></>{{ if gt .Working.Added 0 }} <p:git_added>+{{ .Working.Added }}</>{{ end }}{{ if gt .Working.Modified 0 }} <p:git_modified>~{{ .Working.Modified }}</>{{ end }}{{ if gt .Working.Deleted 0 }} <p:git_deleted>-{{ .Working.Deleted }}</>{{ end }}{{ if gt .Working.Untracked 0 }} <p:git_untracked>?{{ .Working.Untracked }}</>{{ end }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} <p:git_staged></>{{ if gt .Staging.Added 0 }} <p:git_added>+{{ .Staging.Added }}</>{{ end }}{{ if gt .Staging.Modified 0 }} <p:git_modified>~{{ .Staging.Modified }}</>{{ end }}{{ if gt .Staging.Deleted 0 }} <p:git_deleted>-{{ .Staging.Deleted }}</>{{ end }}{{ end }}{{ if gt .StashCount 0 }} <p:purple>󱡡{{ .StashCount }}</>{{ end }} ",
          "foreground": "p:branch",
          "type": "git",
          "style": "plain"
        },
        {
          "type": "jujutsu",
          "style": "plain",
          "foreground": "p:branch",
          "options": {
            "fetch_status": true,
            "fetch_ahead_counter": true,
            "ignore_working_copy": true
          },
          "cache": {
            "duration": "none",
            "strategy": "folder"
          },
          "template": "<p:muted>on</> <p:cyan>󱗆 </> <p:muted>{{ .ChangeID }}</>{{ if .ClosestBookmarks }} {{ .ClosestBookmarks }}{{ end }}{{ if .Working.Changed }} <p:git_modified></>{{ if gt .Working.Added 0 }} <p:git_added>+{{ .Working.Added }}</>{{ end }}{{ if gt .Working.Modified 0 }} <p:git_modified>~{{ .Working.Modified }}</>{{ end }}{{ if gt .Working.Deleted 0 }} <p:git_deleted>-{{ .Working.Deleted }}</>{{ end }}{{ if gt .Working.Moved 0 }} <p:purple>>{{ .Working.Moved }}</>{{ end }}{{ end }} "
        },
        {
          "cache": {
            "duration": "none",
            "strategy": "folder"
          },
          "template": " {{.Profile}}{{if .Region}}@{{.Region}}{{end}}",
          "foreground": "p:orange",
          "type": "aws",
          "style": "plain"
        },
        {
          "cache": {
            "duration": "none",
            "strategy": "folder"
          },
          "template": "{{if .Version}} 󰏗 {{.Version}} {{end}}",
          "foreground": "p:orange",
          "type": "project",
          "style": "plain"
        },
        {
          "options": {
            "extensions": [
              "deno.json",
              "deno.jsonc",
              "deno.lock"
            ]
          },
          "cache": {
            "duration": "none",
            "strategy": "folder"
          },
          "template": "󱍢 {{ .Full }} ",
          "foreground": "p:muted",
          "type": "deno",
          "style": "plain"
        },
        {
          "cache": {
            "duration": "none",
            "strategy": "folder"
          },
          "template": "󰎙 {{ .Full }} ",
          "foreground": "p:green",
          "type": "node",
          "style": "plain"
        },
        {
          "options": {
            "extensions": [
              "package-lock.json"
            ]
          },
          "cache": {
            "duration": "none",
            "strategy": "folder"
          },
          "template": " {{ .Full }} ",
          "foreground": "p:red",
          "type": "npm",
          "style": "plain"
        },
        {
          "options": {
            "extensions": [
              "pnpm-lock.yaml"
            ]
          },
          "cache": {
            "duration": "none",
            "strategy": "folder"
          },
          "template": "󱇚 {{ .Full }} ",
          "foreground": "p:yellow",
          "type": "pnpm",
          "style": "plain"
        },
        {
          "options": {
            "fetch_version": true
          },
          "cache": {
            "duration": "none",
            "strategy": "folder"
          },
          "template": " {{ .Full }} ",
          "foreground": "p:white",
          "type": "bun",
          "style": "plain"
        },
        {
          "cache": {
            "duration": "none",
            "strategy": "folder"
          },
          "template": "󰟓 {{.Full}} ",
          "foreground": "p:cyan",
          "type": "go",
          "style": "plain"
        },
        {
          "cache": {
            "duration": "none",
            "strategy": "folder"
          },
          "template": "󰢱 {{.Full}} ",
          "foreground": "p:blue",
          "type": "lua",
          "style": "plain"
        },
        {
          "cache": {
            "duration": "none",
            "strategy": "folder"
          },
          "template": "󰌟 {{.Full}} ",
          "foreground": "p:purple",
          "type": "php",
          "style": "plain"
        },
        {
          "cache": {
            "duration": "none",
            "strategy": "folder"
          },
          "template": "󰌠 {{.Full}} ",
          "foreground": "p:yellow",
          "type": "python",
          "style": "plain"
        },
        {
          "cache": {
            "duration": "none",
            "strategy": "folder"
          },
          "template": "󰴭 {{.Full}} ",
          "foreground": "p:red",
          "type": "ruby",
          "style": "plain"
        },
        {
          "cache": {
            "duration": "none",
            "strategy": "folder"
          },
          "template": "󱘗 {{.Full}} ",
          "foreground": "p:orange",
          "type": "rust",
          "style": "plain"
        },
        {
          "options": {
            "style": "roundrock",
            "threshold": 0
          },
          "cache": {
            "duration": "none",
            "strategy": "folder"
          },
          "template": "<p:muted>󰔛</> {{ .FormattedMs }} ",
          "foreground": "p:muted",
          "type": "executiontime",
          "style": "plain"
        }
      ],
      "newline": true
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "cache": {
            "duration": "none",
            "strategy": "folder"
          },
          "template": "❯ ",
          "type": "text",
          "style": "plain",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:error{{ end }}",
            "{{ if eq .Code 0 }}p:success{{ end }}"
          ]
        }
      ],
      "newline": true
    }
  ],
  "version": 4
}
