initial-window             = true
confirm-close-surface      = false
shell-integration-features = true
alpha-blending             = linear-corrected

# config-file             = "themes/catppuccin-latte"
# theme                   = TokyoNight Moon
theme                   = Vesper
cursor-style            = block
term                    = xterm-256color
unfocused-split-fill    = "black"
mouse-hide-while-typing = true

copy-on-select           = clipboard
clipboard-read           = allow
clipboard-write          = allow
scrollback-limit         = 10000000

window-save-state        = always
window-colorspace        = "display-p3"
window-inherit-font-size = false
window-padding-x         = 10
window-title-font-family = "Lilex Nerd Font Mono"
font-family              = "Lilex Nerd Font Mono"
font-size                = 16
font-feature             = zero,calt

# Tabs
macos-non-native-fullscreen = true
macos-option-as-alt         = true
macos-titlebar-proxy-icon   = hidden
macos-titlebar-style        = tabs
macos-window-buttons        = visible
macos-icon                  = retro

# Quick Terminal
quick-terminal-position           = right
quick-terminal-size               = 50%,20%
quick-terminal-animation-duration = 0
quick-terminal-autohide           = false

#### KEYBINDING ####
# global
keybind = global:super+ctrl+shift+alt+g=toggle_quick_terminal
keybind = alt+backspace=text:\x1b\x7f
keybind = super+,>,=reload_config
keybind = super+ctrl+alt+equal=close_surface

# Leader key (cmd+k) sequences
keybind = super+,>k=clear_screen
keybind = super+,>n=new_window
keybind = super+,>x=close_surface
#splits/panes
keybind = super+,>h=new_split:left
keybind = super+,>l=new_split:right
keybind = super+,>backslash=new_split:right
keybind = super+,>minus=new_split:down
keybind = super+,>j=new_split:down
keybind = super+,>u=new_split:up
keybind = super+,>z=toggle_split_zoom
keybind = super+,>equal=equalize_splits
#w/o leader key
keybind = super+ctrl+alt+backslash=new_split:right
keybind = super+ctrl+alt+minus=new_split:down
keybind = super+ctrl+alt+h=resize_split:left,50
keybind = super+ctrl+alt+j=resize_split:down,50
keybind = super+ctrl+alt+k=resize_split:up,50
keybind = super+ctrl+alt+l=resize_split:right,50
keybind = super+ctrl+alt+z=toggle_split_zoom
#tabs
keybind = super+,>t=new_tab
keybind = super+,>e=prompt_surface_title
keybind = super+,>1=goto_tab:1
keybind = super+,>2=goto_tab:2
keybind = super+,>3=goto_tab:3
keybind = super+,>4=goto_tab:4
keybind = super+,>5=goto_tab:5
keybind = super+,>6=goto_tab:6
keybind = super+,>7=goto_tab:7
keybind = super+,>8=goto_tab:8

#w/o leader key - move tabs
keybind = ctrl+shift+alt+[=move_tab:-1
keybind = ctrl+shift+alt+]=move_tab:1

# fzf.fish keybindings - Cmd+Ctrl sends Ctrl+Alt sequences to fish
keybind = super+ctrl+f=text:\x1b\x06
# gitlog
keybind = super+ctrl+l=text:\x1b\x0c
# gitstatus
keybind = super+ctrl+s=text:\x1b\x13
# history
keybind = super+ctrl+r=text:\x12
# processes
keybind = super+ctrl+p=text:\x1b\x10
# variables
keybind = super+ctrl+v=text:\x16
