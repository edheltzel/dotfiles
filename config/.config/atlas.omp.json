{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "console_title_template": "{{ .Folder }}",
  "palettes": {
    "template": "macchiato",
    "list": {
      "macchiato": {
        "base": "#24273A",
        "surface": "#363A4F",
        "text": "#CAD3F5",
        "subtext": "#A5ADCB",
        "blue": "#8AADF4",
        "lavender": "#B7BDF8",
        "sapphire": "#7DC4E4",
        "green": "#A6DA95",
        "yellow": "#EED49F",
        "peach": "#F5A97F",
        "maroon": "#EE99A0",
        "red": "#ED8796",
        "mauve": "#C6A0F6",
        "teal": "#8BD5CA",
        "flamingo": "#F0C6C6"
      },
      "frappe": {
        "base": "#303446",
        "surface": "#414559",
        "text": "#C6D0F5",
        "subtext": "#A5ADCE",
        "blue": "#8CAAEE",
        "lavender": "#BABBF1",
        "sapphire": "#85C1DC",
        "green": "#A6D189",
        "yellow": "#E5C890",
        "peach": "#EF9F76",
        "maroon": "#EA999C",
        "red": "#E78284",
        "mauve": "#CA9EE6",
        "teal": "#81C8BE",
        "flamingo": "#EEBEBE"
      }
    }
  },
  "transient_prompt": {
    "template": "<p:lavender>❯</> ",
    "foreground": "p:lavender",
    "background": "transparent"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "background": "p:blue",
          "foreground": "p:base",
          "template": " {{ .Icon }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "",
          "background": "p:surface",
          "foreground": "p:text",
          "options": {
            "style": "agnoster_short",
            "max_depth": 3,
            "folder_icon": "…",
            "home_icon": "~"
          },
          "template": "  {{ .Path }} "
        },
        {
          "type": "git",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "p:base",
          "background": "p:green",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:yellow{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:maroon{{ end }}",
            "{{ if gt .Ahead 0 }}p:sapphire{{ end }}",
            "{{ if gt .Behind 0 }}p:peach{{ end }}"
          ],
          "options": {
            "branch_icon": " ",
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "disable_with_jj": true
          },
          "template": "  {{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }}  {{ .StashCount }}{{ end }} "
        },
        {
          "type": "jujutsu",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "p:base",
          "background": "p:mauve",
          "options": {
            "fetch_status": true,
            "ignore_working_copy": true
          },
          "template": " 󱗆 {{ .ChangeID }}{{ if .ClosestBookmarks }}  {{ .ClosestBookmarks }}{{ end }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "node",
          "style": "plain",
          "foreground": "p:green",
          "template": " 󰎙 {{ .Full }}"
        },
        {
          "type": "bun",
          "style": "plain",
          "foreground": "p:flamingo",
          "options": {
            "fetch_version": true
          },
          "template": "  {{ .Full }}"
        },
        {
          "type": "deno",
          "style": "plain",
          "foreground": "p:teal",
          "template": " 󱍢 {{ .Full }}"
        },
        {
          "type": "go",
          "style": "plain",
          "foreground": "p:sapphire",
          "template": " 󰟓 {{ .Full }}"
        },
        {
          "type": "rust",
          "style": "plain",
          "foreground": "p:peach",
          "template": " 󱘗 {{ .Full }}"
        },
        {
          "type": "python",
          "style": "plain",
          "foreground": "p:yellow",
          "template": " 󰌠 {{ .Full }}"
        },
        {
          "type": "ruby",
          "style": "plain",
          "foreground": "p:red",
          "template": " 󰴭 {{ .Full }}"
        },
        {
          "type": "lua",
          "style": "plain",
          "foreground": "p:blue",
          "template": " 󰢱 {{ .Full }}"
        },
        {
          "type": "php",
          "style": "plain",
          "foreground": "p:mauve",
          "template": " 󰌟 {{ .Full }}"
        },
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "p:subtext",
          "options": {
            "threshold": 500,
            "style": "round"
          },
          "template": " 󰔛 {{ .FormattedMs }}"
        },
        {
          "type": "time",
          "style": "plain",
          "foreground": "p:subtext",
          "template": "  {{ .CurrentDate | date \"15:04\" }}"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "root",
          "style": "plain",
          "foreground": "p:red",
          "template": " "
        },
        {
          "type": "text",
          "style": "plain",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:red{{ end }}",
            "{{ if eq .Code 0 }}p:lavender{{ end }}"
          ],
          "template": "❯ "
        }
      ]
    }
  ],
  "version": 4
}
