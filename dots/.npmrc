ignore-scripts=false

# Note: pnpm v11 does NOT read onlyBuiltDependencies from .npmrc.
# Its global build-script allowlist lives at:
#   ~/Library/pnpm/global/v11/pnpm-workspace.yaml
# under the `allowBuilds:` key. See packages/pnpm-workspace.yaml in this repo
# for the checked-in template that gets installed by packages.sh.
